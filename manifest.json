{
  "manifest_version": 3,
  "name": "Better bombuj si",
  "version": "0.1",
  "description": "Automatically selects a preferred video server.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.bombuj.si/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Select Server"
  },
  "content_scripts": [
    {
      "matches": [ 
        "https://*.bombuj.si/*"
        ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "better_bombuj_si@example.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}