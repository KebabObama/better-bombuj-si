{
  "manifest_version": 3,
  "name": "Better bombuj si",
  "version": "0.2",
  "description": "Automatically remembers and selects your last clicked video server.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.bombuj.si/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.bombuj.si/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "better.bombuj.si@example.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}